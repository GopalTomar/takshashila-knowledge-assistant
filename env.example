# =============================================================================
# .env.example — copy to .env and fill in real values. NEVER commit your .env.
#
#   cp .env.example .env       (Linux/macOS)
#   Copy-Item .env.example .env  (Windows PowerShell)
# =============================================================================

# ── Groq (used by both the Streamlit app and the Mattermost bot) ───────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── Embeddings / retrieval (existing — keep as-is unless you know better) ───────
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
TOP_K=5
MIN_SCORE_THRESHOLD=0.35
CONF_HIGH_THRESHOLD=0.62
CONF_MEDIUM_THRESHOLD=0.48

# ── Reference accuracy / anti-hallucination ────────────────────────────────────
# After the LLM answers, keep ONLY the sources it actually cited (renumbered to
# match), and refuse ungrounded answers instead of showing fake citations.
VERIFY_CITATIONS=true
# Min answer↔context token-overlap for an UNCITED answer to be accepted as
# grounded (otherwise it's refused). Raise to be stricter.
GROUNDING_MIN_OVERLAP=0.18

# ── Commit KB crawl (existing — keep your real values here) ─────────────────────
COMMIT_KB_URL=https://commit.takshashila.org.in/
COMMIT_KB_USERNAME=
COMMIT_KB_PASSWORD=

# =============================================================================
# Mattermost bot integration
# =============================================================================
# Base URL of your Mattermost server (no trailing slash needed; it is stripped).
MATTERMOST_URL=https://matter.takshashila.org.in

# Bot Account personal access token (PREFERRED delivery method).
# Create: System Console → Integrations → Bot Accounts → Add Bot Account.
MATTERMOST_BOT_TOKEN=

# Slash command token. Mattermost generates this when you create the /askkb
# slash command. The bot rejects any request whose token does not match this.
MATTERMOST_SLASH_TOKEN=

# RAG behaviour for the bot (separate from the Streamlit defaults).
MATTERMOST_RAG_TOP_K=5
MATTERMOST_RAG_TEMPERATURE=0.1

# Optional allowlists (comma-separated IDs). Empty = allow everywhere.
MATTERMOST_ALLOWED_TEAM_IDS=
MATTERMOST_ALLOWED_CHANNEL_IDS=

# Safety: maximum characters per Mattermost message before truncation.
MATTERMOST_MAX_MESSAGE_CHARS=12000

# Warm FAISS + embeddings + BM25 at server startup so the first query is fast.
MATTERMOST_WARM_RAG_ON_STARTUP=true

# Optional host/port overrides when running `python integrations/mattermost_bot.py`.
# (uvicorn flags take precedence when you launch with uvicorn directly.)
MATTERMOST_BOT_HOST=0.0.0.0
MATTERMOST_BOT_PORT=8000

# =============================================================================
# Enterprise response routing  (--user / --channel / --group)
# =============================================================================
# Deliver an answer to another user's DM, a channel, or a group DM. Requires the
# same MATTERMOST_BOT_TOKEN used for DM delivery above. No new *required* values —
# the team id needed for channel lookups comes from the slash-command payload.
#
# For `--channel <name>` to work the bot must be a MEMBER of the target channel
# (add the bot to the channel in Mattermost). `--user`/`--group` need only that
# the target usernames exist.
#
# Default behaviour (/askkb <question> and /askkb --me <question>) is unchanged
# whether this is on or off.
MATTERMOST_ENABLE_ROUTING=true

# Bonus: 👤/📢/👥 "Share …" buttons + ⬇️ Download PDF beneath each answer. They
# reuse the already-generated answer (no second RAG run) and open a Mattermost
# dialog to collect the target, so they also need MATTERMOST_BOT_PUBLIC_URL set
# (that URL is where Mattermost sends the dialog submission).
MATTERMOST_ENABLE_SHARE_BUTTONS=true

# Bonus: render an answer to PDF for the ⬇️ Download PDF button (uses pymupdf,
# already a project dependency). Needs the bot token to upload the file.
MATTERMOST_ENABLE_PDF_EXPORT=true
